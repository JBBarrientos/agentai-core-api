{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "MicrosoftGraph": {
    "ResolveUsersEnabled": false
  },
  "Teams": {
    "PollingEnabled": false,
    "PollingIntervalSeconds": 60,
    "PollingLimit": 20,
    "PollingStartupLookbackMinutes": 2,
    "PollingOverlapMinutes": 1,
    "PollingStatePath": "",
    "PollingQuery": "",
    "NotifyExistingOnStartup": false
  },
  "AllowedHosts": "*"
}
